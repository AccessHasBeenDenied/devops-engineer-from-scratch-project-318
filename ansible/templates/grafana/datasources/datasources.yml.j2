{%   set host = groups['prometheus'][0] %}
{%   set target_address = hostvars[host]['ansible_host'] if hostvars[host]['ansible_host'] is defined else host %}

apiVersion: 1
datasources:
  - name: Prometheus
    type: prometheus
    access: proxy
    url: http://{{ target_address }}:9090
    isDefault: true
    editable: true

  - name: Alertmanager
    type: alertmanager
    access: proxy
    url: http://{{ target_address }}:9093
    isDefault: false
    jsonData:
      implementation: prometheus
    editable: true
